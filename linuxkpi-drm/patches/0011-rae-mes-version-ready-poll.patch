 static void mes_v11_0_get_fw_version(struct amdgpu_device *adev)
 {
 	int pipe;
+	unsigned int i;
 
 	/* return early if we have already fetched these */
 	if (adev->mes.sched_version && adev->mes.kiq_version)
 		return;
 
-	/* get MES scheduler/KIQ versions */
-	mutex_lock(&adev->srbm_mutex);
+	/*
+	 * Linux usually observes both firmware heartbeats after the fixed 500 us
+	 * enable delay. AthenaOS MMIO runs from a userspace driver and Athena can
